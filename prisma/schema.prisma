// This is our foundational data model. We separate the System User from 
// the Driver Profile to maintain a clean architecture and enforce RBAC.
// Using Decimal for all financial and weight fields to prevent floating-point errors.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// 1. SYSTEM USERS (Auth & RBAC)
// ------------------------------------------------------
model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  password            String    // Hashed via bcrypt
  name                String
  role                Role
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  isArchived          Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

// ------------------------------------------------------
// 2. CORE CATALOG: VEHICLES & DRIVERS
// ------------------------------------------------------
model Vehicle {
  id                 String        @id @default(cuid())
  registrationNumber String        @unique
  name               String
  type               String
  maxLoadCapacity    Decimal       @db.Decimal(10, 2)
  odometer           Decimal       @db.Decimal(10, 2)
  acquisitionCost    Decimal       @db.Decimal(10, 2)
  status             VehicleStatus @default(AVAILABLE)
  region             String        @default("North")
  isActive           Boolean       @default(true) // Soft delete

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

model Driver {
  id                String       @id @default(cuid())
  name              String
  licenseNumber     String       @unique
  licenseCategory   String
  licenseExpiryDate DateTime
  contactNumber     String
  safetyScore       Decimal      @db.Decimal(5, 2)
  status            DriverStatus @default(AVAILABLE)
  isActive          Boolean      @default(true) // Soft delete

  trips Trip[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

// ------------------------------------------------------
// 3. TRANSACTIONS: TRIPS & MAINTENANCE
// ------------------------------------------------------
model Trip {
  id              String     @id @default(cuid())
  source          String
  destination     String
  cargoWeight     Decimal    @db.Decimal(10, 2)
  plannedDistance Decimal    @db.Decimal(10, 2)
  revenue         Decimal?   @db.Decimal(10, 2) // Added for ROI calculations
  status          TripStatus @default(DRAFT)
  finalOdometer   Decimal?   @db.Decimal(10, 2)
  fuelConsumed    Decimal?   @db.Decimal(10, 2)

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  driverId  String
  driver    Driver  @relation(fields: [driverId], references: [id])
  expenses  Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

model MaintenanceLog {
  id          String            @id @default(cuid())
  serviceType String
  cost        Decimal           @db.Decimal(10, 2)
  date        DateTime          @default(now())
  status      MaintenanceStatus @default(ACTIVE)

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MaintenanceStatus {
  ACTIVE
  COMPLETED
}

// ------------------------------------------------------
// 4. FINANCIALS: FUEL & EXPENSES
// ------------------------------------------------------
model FuelLog {
  id     String   @id @default(cuid())
  date   DateTime @default(now())
  liters Decimal  @db.Decimal(10, 2)
  cost   Decimal  @db.Decimal(10, 2)

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id     String   @id @default(cuid())
  type   String   // e.g., TOLL, MISC
  amount Decimal  @db.Decimal(10, 2)
  date   DateTime @default(now())

  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id])
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}